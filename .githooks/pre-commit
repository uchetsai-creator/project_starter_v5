#!/usr/bin/env bash
# project_starter_v5 — verification pre-commit hook
# Runs quality checks automatically on every git commit. Blocks on failure.
#
# Install (once per project clone):
#   cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# Requires .project-starter.yml at the project root with:
#   project_type: <your-type>
#   docs_path: docs/

set -euo pipefail

# Staged file list — collected once, used by multiple checks
STAGED=$(git diff --cached --name-only 2>/dev/null || true)

# ── Registry schema ───────────────────────────────────────────────────────────
# Trigger: always (registry is the shared dependency of all validators)
# Catches: malformed project type (webapp vs web-app), missing required fields, bad values
if command -v python3 &>/dev/null && [ -f "templates/script/validators/verify_registry.py" ] && [ -f "document-registry.yaml" ]; then
    echo "  → verify_registry.py ..."
    python3 "templates/script/validators/verify_registry.py" --registry document-registry.yaml 2>&1 || {
        echo "❌  pre-commit: registry schema validation failed — commit blocked."
        exit 1
    }
fi

# ── Framework integrity ────────────────────────────────────────────────────────
# Trigger: running inside the project_starter_v5 framework repo (templates/script/ present)
# Catches: stale pointer, matrix gap, or token budget violation
if command -v python3 &>/dev/null && [ -f "templates/script/framework/verify_framework.py" ]; then
    echo "  → verify_framework.py --strict ..."
    python3 "templates/script/framework/verify_framework.py" --strict 2>&1 || {
        echo "❌  pre-commit: framework integrity check failed — commit blocked."
        exit 1
    }
fi

# ── Read .project-starter.yml ─────────────────────────────────────────────────
CONFIG=".project-starter.yml"
PROJECT_TYPE=""
DOCS_PATH="docs"

if [ -f "$CONFIG" ]; then
    PROJECT_TYPE=$(grep '^project_type:' "$CONFIG" | sed 's/project_type:[[:space:]]*//' | tr -d "\"' ")
    DOCS_CANDIDATE=$(grep '^docs_path:' "$CONFIG" | sed 's/docs_path:[[:space:]]*//' | tr -d "\"' /")
    [ -n "$DOCS_CANDIDATE" ] && DOCS_PATH="$DOCS_CANDIDATE"
fi

if [ -z "$PROJECT_TYPE" ]; then
    echo "⚠️  pre-commit: .project-starter.yml not found or project_type missing — skipping verification."
    exit 0
fi

# ── Placeholder guard ─────────────────────────────────────────────────────────
# Catches: committing with the template placeholder value still in project_type
if echo "$PROJECT_TYPE" | grep -qE '^\[.+\]$'; then
    echo "❌  pre-commit: .project-starter.yml project_type is still a placeholder ('$PROJECT_TYPE')."
    echo "    Replace it with your actual project type before committing."
    echo "    Valid values: web-app | cli-tool | library | data-pipeline | ml-pipeline | microservices | llm-app | iac | mobile-app"
    exit 1
fi

echo "pre-commit: project-type=$PROJECT_TYPE  docs=$DOCS_PATH"
PASS=true

# 1. Document completeness + content quality
if command -v python3 &>/dev/null && [ -f "docs/script/validators/verify_docs.py" ]; then
    echo "  → verify_docs.py --content ..."
    python3 "docs/script/validators/verify_docs.py" \
        --project-type "$PROJECT_TYPE" --docs "$DOCS_PATH" --content --strict 2>&1 || PASS=false
else
    echo "  ⚠️  docs/script/validators/verify_docs.py not found — skipping"
fi

# 2. Log quality
if [ -f "docs/script/validators/verify_logs.py" ]; then
    echo "  → verify_logs.py ..."
    python3 "docs/script/validators/verify_logs.py" \
        --project-type "$PROJECT_TYPE" --docs "$DOCS_PATH" --strict 2>&1 || PASS=false
fi

# 3. Test report quality
if [ -f "docs/script/validators/verify_tests.py" ]; then
    echo "  → verify_tests.py ..."
    python3 "docs/script/validators/verify_tests.py" \
        --project-type "$PROJECT_TYPE" --docs "$DOCS_PATH" --strict 2>&1 || PASS=false
fi

# 4. Document content quality
if [ -f "docs/script/validators/verify_content.py" ]; then
    echo "  → verify_content.py ..."
    python3 "docs/script/validators/verify_content.py" \
        --project-type "$PROJECT_TYPE" --docs "$DOCS_PATH" --strict 2>&1 || PASS=false
fi

# ── AGENTS.md token budget ─────────────────────────────────────────────────────
# Trigger: AGENTS.md in staged files
# Catches: AGENTS.md growing past the 200-line limit
AGENTS_FILE=$(printf '%s\n' "$STAGED" | grep -E '(^|/)AGENTS\.md$' | head -1 || true)
if [ -n "$AGENTS_FILE" ]; then
    AGENTS_LINES=$(git show ":$AGENTS_FILE" 2>/dev/null | wc -l || echo 0)
    if [ "$AGENTS_LINES" -gt 200 ]; then
        echo "  ❌ AGENTS.md is $AGENTS_LINES lines — token budget exceeded (limit: 200)"
        PASS=false
    else
        echo "  ✅ AGENTS.md token budget OK ($AGENTS_LINES / 200 lines)"
    fi
fi

# ── Changelog audit trail ──────────────────────────────────────────────────────
# Trigger: any specs/*.md or architecture/*.md staged
# Severity: warn (non-blocking) — reminder only
# Catches: silent spec changes with no audit trail entry in changelog.md
SPEC_ARCH_STAGED=$(printf '%s\n' "$STAGED" | grep -E '(specs/|architecture/).*\.md$' || true)
if [ -n "$SPEC_ARCH_STAGED" ]; then
    CHANGELOG_STAGED=$(printf '%s\n' "$STAGED" | grep -E '(^|/)changelog\.md$' | head -1 || true)
    if [ -z "$CHANGELOG_STAGED" ]; then
        echo "  ⚠️  spec or architecture files changed without changelog.md — add an audit trail entry"
    fi
fi

# ── Closeout completeness ──────────────────────────────────────────────────────
# Trigger: current-state.md staged with Status containing "Complete"
# Catches: task marked done but Closeout section left with unfilled placeholders
CS_FILE=$(printf '%s\n' "$STAGED" | grep -E '(^|/)current-state\.md$' | head -1 || true)
if [ -n "$CS_FILE" ]; then
    CS_CONTENT=$(git show ":$CS_FILE" 2>/dev/null || true)
    CS_STATUS=$(printf '%s\n' "$CS_CONTENT" | grep -iE '^\*\*Status:\*\*' | head -1 || true)
    if printf '%s\n' "$CS_STATUS" | grep -qi 'Complete'; then
        CLOSEOUT_SECTION=$(printf '%s\n' "$CS_CONTENT" | awk '/^## Closeout/{p=1} p{print}')
        if printf '%s\n' "$CLOSEOUT_SECTION" | grep -qE '__+|<!--'; then
            echo "  ❌ current-state.md Status is Complete but Closeout section has unfilled placeholders (___) or comments (<!--)"
            PASS=false
        fi
    fi
fi

# ── Writing Audience violations ────────────────────────────────────────────────
# Trigger: any spec-facing document staged
# Spec-facing: business-rules.md, pipeline-contract.md, research.md, quickstart.md,
#              architecture/*.md, modules/*/*-module-data-flow.md
# Catches: sprint/task references written into stakeholder-facing documents
SPEC_FACING_STAGED=$(printf '%s\n' "$STAGED" | grep -E \
    '(business-rules|pipeline-contract|research|quickstart)\.md$|(^|/)architecture/.*\.md$|modules/.*-module-data-flow\.md$' \
    || true)
if [ -n "$SPEC_FACING_STAGED" ]; then
    FOUND_VIOLATIONS=false
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        VIOLATIONS=$(git show ":$file" 2>/dev/null \
            | grep -nE 'Sprint [0-9]+|Task [0-9]+|\(S[0-9]+\)' || true)
        if [ -n "$VIOLATIONS" ]; then
            if [ "$FOUND_VIOLATIONS" = false ]; then
                echo "  ❌ Writing Audience violations in spec-facing documents:"
                FOUND_VIOLATIONS=true
            fi
            echo "     $file:"
            printf '%s\n' "$VIOLATIONS" | sed 's/^/       /'
        fi
    done <<< "$SPEC_FACING_STAGED"
    [ "$FOUND_VIOLATIONS" = true ] && PASS=false
fi

# ── Spec ↔ Code validation ─────────────────────────────────────────────────────
# Trigger: any spec contract document staged (spec change → validate code still matches)
# Catches: spec–code drift introduced alongside a spec update
# Note: verify_spec_code.py exits 0 if --adapter/--spec/--src are not configured.
SPEC_CONTRACT_STAGED=$(printf '%s\n' "$STAGED" \
    | grep -E '(pipeline-contract|cli-contract|api-contract|public-api|llm-contract|topology|mobile-contract)\.md$' || true)
if [ -n "$SPEC_CONTRACT_STAGED" ] && [ -f "docs/script/validators/verify_spec_code.py" ]; then
    echo "  → verify_spec_code.py (spec contract staged) ..."
    python3 "docs/script/validators/verify_spec_code.py" --strict 2>&1 || PASS=false
fi

if [ "$PASS" = false ]; then
    echo ""
    echo "❌  pre-commit: verification failed — commit blocked."
    echo "    Fix the issues above, then re-run: git commit"
    exit 1
fi

echo "✅  pre-commit: all checks passed."
